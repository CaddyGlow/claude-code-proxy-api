{
	"name": "dashboard",
	"private": true,
	"version": "0.1.0-dev145",
	"type": "module",
	"scripts": {
		"sync-version": "node scripts/sync-version.js",
		"dev": "bunx --bun vite dev",
		"build": "bun run sync-version && bunx --bun vite build",
		"build:prod": "bun run sync-version && bunx --bun vite build && rm -rf ../ccproxy/static/dashboard && cp -r build ../ccproxy/static/dashboard",
		"preview": "bunx --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "bunx sv check --tsconfig ./tsconfig.json && bunx biome check",
		"check:watch": "bunx sv check --tsconfig ./tsconfig.json --watch",
		"lint": "bunx biome lint",
		"format": "bunx biome format --write",
		"format:check": "bunx biome format",
		"test": "vitest run --coverage",
		"test:watch": "vitest",
		"test:ci": "vitest run --coverage --reporter=verbose",
		"e2e": "playwright test",
		"e2e:ci": "playwright test --reporter=line"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.1",
		"@playwright/test": "^1.54.1",
		"@sveltejs/adapter-auto": "^6.0.0",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.8",
		"@types/jsdom": "^21.1.7",
		"@vitest/coverage-v8": "^3.2.4",
		"jsdom": "^26.1.0",
		"msw": "^2.10.4",
		"playwright": "^1.54.1",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^7.0.4",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.1.11",
		"chart.js": "^4.5.0",
		"chartjs-adapter-date-fns": "^3.0.0",
		"d3-array": "^3.2.4",
		"d3-scale": "^4.0.2",
		"date-fns": "^4.1.0",
		"happy-dom": "^18.0.1",
		"layerchart": "^1.0.11",
		"tailwindcss": "^4.1.11"
	}
}
